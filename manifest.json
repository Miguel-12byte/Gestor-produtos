<!doctype html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Gestor de Produtos</title>

<style>
body{
  margin:0;
  font-family: Arial, sans-serif;
  background:#0f172a;
  color:#fff;
}

header{
  padding:15px;
  background:#2563eb;
  font-weight:bold;
  text-align:center;
}

.container{
  padding:15px;
  max-width:600px;
  margin:auto;
}

input, button{
  width:100%;
  padding:12px;
  margin:6px 0;
  border:none;
  border-radius:8px;
  font-size:14px;
}

input{
  background:#111827;
  color:#fff;
}

button{
  background:#2563eb;
  color:#fff;
  cursor:pointer;
  transition:0.2s;
}

button:hover{
  opacity:0.9;
}

.card{
  background:#111827;
  padding:12px;
  border-radius:8px;
  margin-top:10px;
  display:flex;
  justify-content:space-between;
  align-items:center;
}

.actions{
  display:flex;
}

.actions button{
  width:auto;
  margin-left:5px;
  padding:6px 10px;
  font-size:12px;
}

.delete{
  background:#dc2626;
}

.total{
  margin-top:15px;
  font-weight:bold;
  text-align:right;
  font-size:16px;
}
</style>
</head>

<body>

<header>📦 Gestor de Produtos</header>

<div class="container">

<h3>Cadastrar Produto</h3>

<input id="name" placeholder="Nome do produto">
<input id="price" type="number" step="0.01" placeholder="Preço">

<button id="btnAdd">Salvar</button>

<h3>Lista</h3>
<div id="list"></div>

<div class="total" id="total"></div>

</div>

<script>
const nameInput = document.getElementById('name')
const priceInput = document.getElementById('price')
const list = document.getElementById('list')
const totalEl = document.getElementById('total')
const btnAdd = document.getElementById('btnAdd')

let products = JSON.parse(localStorage.getItem('produtos') || '[]')

// 🔄 salvar
function save(){
  localStorage.setItem('produtos', JSON.stringify(products))
}

// ➕ adicionar
function addProduct(){
  const name = nameInput.value.trim()
  let price = parseFloat(priceInput.value)

  if(!name){
    alert('Digite o nome do produto')
    return
  }

  if(isNaN(price)) price = 0

  products.push({ name, price })

  save()
  clearInputs()
  render()
}

// ✏️ editar
function editProduct(index){
  const p = products[index]

  const newName = prompt('Editar nome:', p.name)
  if(!newName) return

  let newPrice = parseFloat(prompt('Editar preço:', p.price))
  if(isNaN(newPrice)) newPrice = 0

  products[index] = {
    name: newName.trim(),
    price: newPrice
  }

  save()
  render()
}

// ❌ remover
function removeProduct(index){
  if(confirm('Deseja remover este produto?')){
    products.splice(index,1)
    save()
    render()
  }
}

// 🧹 limpar inputs
function clearInputs(){
  nameInput.value = ''
  priceInput.value = ''
  nameInput.focus()
}

// 🎨 render
function render(){
  list.innerHTML = ''
  let total = 0

  products.forEach((p, i)=>{
    total += p.price

    const item = document.createElement('div')
    item.className = 'card'

    item.innerHTML = `
      <div>
        <b>${p.name}</b><br>
        R$ ${p.price.toFixed(2)}
      </div>
      <div class="actions">
        <button onclick="editProduct(${i})">Editar</button>
        <button class="delete" onclick="removeProduct(${i})">Excluir</button>
      </div>
    `

    list.appendChild(item)
  })

  totalEl.innerText = "Total: R$ " + total.toFixed(2)
}

// 🎯 eventos
btnAdd.addEventListener('click', addProduct)

// permitir Enter
priceInput.addEventListener('keypress', e=>{
  if(e.key === 'Enter') addProduct()
})

render()
</script>

</body>
</html>
